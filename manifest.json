{
  "manifest_version": 3,
  "name": "Jira Daily Update",
  "version": "0.1.0",
  "description": "Get your Jira daily update by date with worklog time and copy-ready format.",
  "action": {
    "default_title": "Jira Daily Update",
    "default_popup": "dist/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_page": "dist/options/options.html",
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": ["https://*.atlassian.net/*"],
  "optional_host_permissions": ["https://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "24": "icons/icon24.png",
    "32": "icons/icon32.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  }
}

